NODE_ENV=production
PORT=3000
SITE_URL=https://your-vercel-domain.example
CORS_ORIGINS=https://your-vercel-domain.example

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=website@example.com
SMTP_PASS=replace-with-smtp-password
BUSINESS_EMAIL_TO=admin@example.com
BUSINESS_EMAIL_FROM=website@example.com

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash
JWT_SECRET=replace-with-a-long-random-secret

RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TO_NUMBER=
WHATSAPP_API_VERSION=v20.0

MAX_REQUEST_BODY_BYTES=262144
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20
ADMIN_RATE_LIMIT_MAX=60
